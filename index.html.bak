<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"><meta name="theme-color" content="#080808"><title>The Pack | Black Dog Brewing Company</title><link rel="manifest" href="manifest.webmanifest"><link rel="icon" href="assets/app-icon.svg"><link rel="stylesheet" href="styles.css"></head><body><div class="app"><header><div><span>BLACK DOG BREWING COMPANY</span><strong>The Pack</strong></div><button id="adminBtn">Admin</button><button id="avatarBtn" class="avatar">JK</button></header><main id="view"></main><nav><button data-view="home" class="active">⌂<small>Home</small></button><button data-view="events">◫<small>Events</small></button><button data-view="passport">◒<small>Passport</small></button><button data-view="journey">★<small>Journey</small></button><button data-view="profile">●<small>Profile</small></button></nav></div><div id="modal" class="modal"></div><div id="toast" class="toast"></div><script src="app.js"></script></body></html>